<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <style>
        *{
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: Arial, sans-serif;
        }

        body{
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            background-color: #f4f4f4;
        }

        .container{
            background-color: white;
            padding: 30px;
            border-radius: 10px;
            box-shadow: 0 0 10px rgba(0,0,0,0.2);
            text-align: center;
        }

        a{
            display: block;
            text-decoration: none;
            background-color: #007bff;
            color: white;
            padding: 12px 20px;
            margin: 10px 0;
            border-radius: 5px;
            transition: 0.3s;
            font-size: 18px;
        }

        a:hover{
            background-color: #0056b3;
        }
    </style>
</head>

<body>
    <a href="localhost:3000/getdata">Get Data</a>
    <br>
    <br>
    <a href="localhost:3000/insertdata">Insert Data</a>
</body>

</html>