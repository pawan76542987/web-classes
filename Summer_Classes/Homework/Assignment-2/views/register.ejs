<!DOCTYPE html>
<html>
<head>
    <title>Register</title>
</head>
<body>

<h1>Register</h1>

<form action="/register" method="POST">

    <input
        type="text"
        name="name"
        placeholder="Enter Name"
    >

    <br><br>

    <input
        type="email"
        name="email"
        placeholder="Enter Email"
    >

    <br><br>

    <button type="submit">
        Register
    </button>

</form>

</body>
</html>