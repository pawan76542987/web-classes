<!DOCTYPE html>
<html>
<head>
    <title>Login</title>
</head>
<body>

<h1>Login</h1>

<form action="/login" method="POST">

    <input
        type="email"
        name="email"
        placeholder="Enter Email"
    >

    <br><br>

    <input
        type="password"
        name="password"
        placeholder="Enter Password"
    >

    <br><br>

    <button type="submit">
        Login
    </button>

</form>

</body>
</html>